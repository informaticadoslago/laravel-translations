{
    "name": "informaticadoslago/laravel-translations",
    "description": "Traduce ficheros de idioma de Laravel (PHP y JSON) con Google Translate u OpenAI, con caché en base de datos y peticiones en lote.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "translations", "i18n", "lang", "google-translate", "openai"],
    "authors": [
        {
            "name": "Alberto Lago Rodríguez",
            "homepage": "https://github.com/informaticadoslago"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "InformaticadosLago\\Translations\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "InformaticadosLago\\Translations\\TranslationsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
